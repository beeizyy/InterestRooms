@model List<InterestRooms.Models.Room>

<h2>My Rooms</h2>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Category</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.Name</td>
                    <td>@room.Description</td>
                    <td>@room.Category</td>
                    <td>
                        <a asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-secondary">Open</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>You have not joined any rooms yet.</p>
}