@model List<InterestRooms.Models.Room>

<h2>My Rooms</h2>

@if (Model.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Description</th>
                <th>Category</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var room in Model)
            {
                <tr>
                    <td>@room.Name</td>
                    <td>@room.Description</td>
                    <td>@room.Category</td>
                    <td>
                        <a asp-controller="Rooms" asp-action="Details" asp-route-id="@room.Id" class="btn btn-sm btn-secondary">
                            Open
                        </a>

                        <a asp-controller="Rooms" asp-action="Requests" asp-route-roomId="@room.Id" class="btn btn-sm btn-primary">
                            Requests
                        </a>

                        <form asp-controller="Rooms" asp-action="Delete" method="post" style="display:inline;"
                              onsubmit="return confirm('Are you sure you want to delete this room?');">
                            <input type="hidden" name="roomId" value="@room.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                Delete
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>You have not joined any rooms yet.</p>
}