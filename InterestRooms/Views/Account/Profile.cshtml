@model InterestRooms.ViewModels.ProfileViewModel

<h2>My Profile</h2>

<div class="mb-3">
    <strong>Username:</strong> @Model.Username
</div>

@if (!string.IsNullOrEmpty(Model.CurrentProfileImagePath))
{
    <div class="mb-3">
        <img src="@Model.CurrentProfileImagePath"
             alt="Profile Photo"
             width="120"
             height="120"
             style="object-fit:cover; border-radius:50%;" />
    </div>
}
else
{
    <p>No profile photo uploaded yet.</p>
}

<form asp-action="Profile" method="post" enctype="multipart/form-data">
    <div class="mb-3">
        <label class="form-label">Upload Profile Photo</label>
        <input asp-for="ProfileImage" type="file" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Save Photo</button>
</form>